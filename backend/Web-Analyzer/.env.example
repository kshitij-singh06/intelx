# Environment Configuration
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_ENV=development
PORT=5000

# API Configuration
API_TIMEOUT_LIMIT=20000
API_CORS_ORIGIN=*
API_ENABLE_RATE_LIMIT=false

# Disable everything (emergency shutdown)
# DISABLE_EVERYTHING=false

# External API Keys (Optional - required for specific features)
# BuiltWith API Key - Required for: features
BUILT_WITH_API_KEY=your_builtwith_api_key_here

# Tranco List Credentials - Optional for: rank (auth not required but recommended)
TRANCO_USERNAME=your_tranco_username
TRANCO_API_KEY=your_tranco_api_key

# Chrome/Chromium Path - Required for: screenshot
CHROME_PATH=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver
