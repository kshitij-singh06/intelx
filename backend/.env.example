# IntelX Backend - Shared Environment Variables
# This file is used by the unified docker-compose.yml

# ============================================
# API Keys
# ============================================
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Database (Steg-Analyzer)
# ============================================
POSTGRES_USER=intelxuser
POSTGRES_PASSWORD=intelxpass
POSTGRES_DB=intelx
DATABASE_URL=postgresql://intelxuser:intelxpass@steg-postgres:5432/intelx

# ============================================
# Redis (Steg-Analyzer)
# ============================================
REDIS_URL=redis://steg-redis:6379/0
RQ_DASHBOARD_REDIS_URL=redis://steg-redis:6379/0

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=production
FLASK_DEBUG=false
PYTHONUNBUFFERED=1

# ============================================
# Port Configuration (Internal)
# ============================================
# All services run on port 5000 internally
# External ports are mapped in docker-compose.yml:
# - Malware-Analyzer: 5001
# - Steg-Analyzer: 5002
# - Recon-Analyzer: 5003
# - Url-Analyzer: 5004
# - Web-Analyzer: 5005